package vendors

import (
	"github.com/tagawa0525/app_man/internal/handler/middleware"
	"github.com/tagawa0525/app_man/internal/view/layout"
)

// FormInput は new / edit 兼用フォームに渡す入力値。バリデーション失敗時の
// 再表示にも使えるよう、生の文字列のまま保持する。
type FormInput struct {
	Name string
	URL  string
	Note string
}

// FormProps は new / edit 兼用フォームに渡す描画引数。
//
//   - Action  : <form action=...> の送信先 (/vendors または /vendors/:id)
//   - Title   : ページタイトル
//   - Submit  : submit ボタンのラベル
//   - Input   : 入力済み値 (バリデーション失敗時の再表示)
//   - Errors  : フィールド名 → エラーメッセージ
type FormProps struct {
	Action string
	Title  string
	Submit string
	Input  FormInput
	Errors map[string]string
}

templ Form(role middleware.Role, props FormProps) {
	@layout.Base(layout.BaseProps{
		Title:     props.Title,
		Role:      role,
		CSRFToken: middleware.DummyCSRFToken,
	}) {
		<section class="page-vendors-form">
			<header class="page-header">
				<h1>{ props.Title }</h1>
			</header>

			<form method="post" action={ templ.SafeURL(props.Action) } class="vform">
				@layout.CSRFInput(middleware.DummyCSRFToken)

				<div class="field">
					<label for="name">名前 <span class="required">*</span></label>
					<input id="name" type="text" name="name" value={ props.Input.Name } required/>
					if msg, ok := props.Errors["name"]; ok {
						<p class="field-error">{ msg }</p>
					}
				</div>

				<div class="field">
					<label for="url">URL</label>
					<input id="url" type="url" name="url" value={ props.Input.URL }/>
					if msg, ok := props.Errors["url"]; ok {
						<p class="field-error">{ msg }</p>
					}
				</div>

				<div class="field">
					<label for="note">メモ</label>
					<textarea id="note" name="note" rows="4">{ props.Input.Note }</textarea>
				</div>

				<div class="form-actions">
					<button type="submit" class="btn btn-primary">{ props.Submit }</button>
					<a class="btn" href="/vendors">キャンセル</a>
				</div>
			</form>
		</section>
	}
}
