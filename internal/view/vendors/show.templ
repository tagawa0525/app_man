package vendors

import (
	"github.com/tagawa0525/app_man/internal/handler/middleware"
	"github.com/tagawa0525/app_man/internal/repository"
	"github.com/tagawa0525/app_man/internal/view/layout"
)

// ShowProps は GET /vendors/:id 表示で必要な集約。
type ShowProps struct {
	Vendor   repository.Vendor
	Products []repository.Product
	Flash    string
}

templ Show(role middleware.Role, props ShowProps) {
	@layout.Base(layout.BaseProps{
		Title:     props.Vendor.Name,
		Role:      role,
		Flash:     props.Flash,
		CSRFToken: middleware.DummyCSRFToken,
	}) {
		<section class="page-vendors-show">
			<header class="page-header">
				<h1>{ props.Vendor.Name }</h1>
				if canEdit(role) {
					<div class="page-actions">
						<a class="btn" href={ templ.SafeURL("/vendors/" + itoa(props.Vendor.ID) + "/edit") }>編集</a>
						<form method="post" action={ templ.SafeURL("/vendors/" + itoa(props.Vendor.ID) + "/delete") }
							onsubmit="return confirm('このベンダーを削除しますか?');" class="inline">
							@layout.CSRFInput(middleware.DummyCSRFToken)
							<button type="submit" class="btn btn-danger">削除</button>
						</form>
					</div>
				}
			</header>

			<dl class="details">
				<dt>URL</dt>
				<dd>
					if props.Vendor.Url != nil {
						<a href={ templ.SafeURL(*props.Vendor.Url) } target="_blank" rel="noopener">{ *props.Vendor.Url }</a>
					}
				</dd>
				<dt>メモ</dt>
				<dd>
					if props.Vendor.Note != nil {
						{ *props.Vendor.Note }
					}
				</dd>
			</dl>

			<h2>このベンダーの製品</h2>
			if len(props.Products) == 0 {
				<p class="empty">登録された製品はありません。</p>
			} else {
				<ul class="product-list">
					for _, p := range props.Products {
						<li>
							<a href={ templ.SafeURL("/products/" + itoa(p.ID)) }>
								{ p.CanonicalName }
								if p.Edition != nil && *p.Edition != "" {
									{ " (" + *p.Edition + ")" }
								}
							</a>
						</li>
					}
				</ul>
			}
		</section>
	}
}
